{
  "interface": [
{% set interfaces_with_ip = interfaces | selectattr('ip', 'defined') | list %}
{% if loopback_ip is defined %}
    {
      "name": "system0",
      "admin-state": "enable",
      "subinterface": [
        {
          "index": 0,
          "admin-state": "enable",
          "ipv4": {
            "admin-state": "enable",
            "address": [
              {
                "ip-prefix": "{{ loopback_ip }}"
              }
            ]
          }
        }
      ]
    }{% if interfaces_with_ip | length > 0 %},{% endif %}

{% endif %}
{% for iface in interfaces_with_ip %}
    {
      "name": "{{ iface.name }}",
      "admin-state": "enable",
      "subinterface": [
        {
          "index": 0,
          "admin-state": "enable",
          "ipv4": {
            "admin-state": "enable",
            "address": [
              {
                "ip-prefix": "{{ iface.ip }}"
              }
            ]
          }
        }
      ]
    }{% if not loop.last %},{% endif %}

{% endfor %}
  ],
  "network-instance": [
    {
      "name": "default",
      "type": "default",
      "admin-state": "enable",
      "interface": [
{% if loopback_ip is defined %}
        {
          "name": "system0.0"
        }{% if interfaces_with_ip | length > 0 %},{% endif %}

{% endif %}
{% for iface in interfaces_with_ip %}
        {
          "name": "{{ iface.name }}.0"
        }{% if not loop.last %},{% endif %}

{% endfor %}
      ],
      "protocols": {
        "bgp": {
          "admin-state": "enable",
          "autonomous-system": {{ asn }},
          "router-id": "{{ router_id }}",
          "afi-safi": [
            {
              "afi-safi-name": "ipv4-unicast",
              "admin-state": "enable"
            }
          ],
          "group": [
            {
              "group-name": "underlay",
              "afi-safi": [
                {
                  "afi-safi-name": "ipv4-unicast",
                  "admin-state": "enable"
                }
              ]
            }
          ],
          "neighbor": [
{% set neighbors = interfaces | selectattr('neighbor_ip', 'defined') | list %}
{% for iface in neighbors %}
            {
              "peer-address": "{{ iface.neighbor_ip }}",
              "peer-as": {{ iface.neighbor_asn }},
              "peer-group": "underlay",
              "admin-state": "enable"
            }{% if not loop.last %},{% endif %}

{% endfor %}
          ]
        }
      }
    }
  ]
}
