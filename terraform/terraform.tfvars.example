# Copy to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars

cloud_provider = "hetzner"

# SSH keys — used for server access and provisioning
ssh_public_key_path  = "~/.ssh/id_ed25519.pub"
ssh_private_key_path = "~/.ssh/id_ed25519"

# Server config
server_name = "dclab"
server_type = "cpx31"    # cpx11=2c/2GB, cpx21=3c/4GB, cpx31=4c/8GB, cpx41=8c/16GB
location    = "hil"      # ash (Ashburn, VA), hil (Hillsboro, OR), nbg1 (Nuremberg), hel1 (Helsinki)
image       = "ubuntu-24.04"

# Hetzner API token — set via environment variable instead of tfvars:
#   export HCLOUD_TOKEN="your-token-here"
