# Remote lab server configuration
# Copy to .env and fill in your values:  cp .env.example .env

# Remote server SSH connection
LAB_HOST=                    # IP or hostname (e.g., 65.108.x.x)
LAB_USER=root                # SSH user (default: root for Hetzner)
LAB_SSH_KEY=~/.ssh/id_ed25519  # Path to SSH private key
LAB_PORT=22                  # SSH port

# Remote paths
LAB_REMOTE_DIR=/opt/containerlab  # Where the repo is synced on the remote

# Default topology vendor
LAB_VENDOR=srlinux           # srlinux or sonic
