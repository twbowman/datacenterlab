#!/bin/bash
# Lab Management Script
# Run with: orb -m clab ./lab <command>

COMMAND="${1:-help}"

case $COMMAND in
  start|deploy)
    echo "🚀 Deploying network lab..."
    ./scripts/deploy.sh
    ;;
    
  stop|destroy)
    echo "🛑 Destroying network lab..."
    ./scripts/destroy.sh
    ;;
    
  restart)
    echo "🔄 Restarting network lab..."
    ./scripts/destroy.sh
    sleep 2
    ./scripts/deploy.sh
    ;;
    
  mon-start)
    echo "🚀 Deploying monitoring stack..."
    ./scripts/deploy-monitoring.sh
    ;;
    
  mon-stop)
    echo "🛑 Destroying monitoring stack..."
    ./scripts/destroy-monitoring.sh
    ;;
    
  status)
    echo "📊 Lab Status"
    echo ""
    echo "=== Network Lab ==="
    docker ps --filter "name=clab-gnmi-clos" --format "table {{.Names}}\t{{.Status}}" | grep -v monitoring
    echo ""
    echo "=== Monitoring Stack ==="
    docker ps --filter "name=clab-monitoring" --format "table {{.Names}}\t{{.Status}}"
    echo ""
    echo "=== Access URLs ==="
    echo "From host machine (outside orb VM):"
    echo "  Grafana:    http://localhost:3000 (admin/admin)"
    echo "  Prometheus: http://localhost:9090"
    echo "  gNMIc:      http://localhost:9273/metrics"
    echo ""
    echo "From inside orb VM (for scripts):"
    echo "  Grafana:    http://172.20.20.2:3000"
    echo "  Prometheus: http://172.20.20.3:9090"
    echo "  gNMIc:      http://172.20.20.5:9273/metrics"
    ;;
    
  logs)
    NODE="${2:-spine1}"
    echo "📜 Logs for clab-gnmi-clos-$NODE"
    docker logs "clab-gnmi-clos-$NODE" --tail 50
    ;;
    
  shell)
    NODE="${2:-spine1}"
    echo "🐚 Connecting to clab-gnmi-clos-$NODE..."
    docker exec -it "clab-gnmi-clos-$NODE" bash
    ;;
    
  sr_cli)
    NODE="${2:-spine1}"
    echo "🔧 Connecting to SR Linux CLI on clab-gnmi-clos-$NODE..."
    docker exec -it "clab-gnmi-clos-$NODE" sr_cli
    ;;
    
  configure)
    echo "⚙️  Configuring network with Ansible..."
    ansible-playbook -i ansible/inventory.yml ansible/site.yml
    ;;
    
  verify)
    echo "✅ Verifying network configuration..."
    ansible-playbook -i ansible/inventory.yml ansible/methods/gnmicli/playbooks/verify.yml
    ;;
    
  verify-detailed)
    echo "✅ Detailed verification..."
    ansible-playbook -i ansible/inventory.yml ansible/methods/gnmicli/playbooks/verify-detailed.yml
    ;;
    
  analyze-links)
    echo "📊 Analyzing link utilization..."
    # Check if requests module is available
    if ! python3 -c "import requests" 2>/dev/null; then
        echo "⚠️  Python 'requests' module not found"
        echo ""
        echo "Install options:"
        echo "  1. System package:  sudo apt install python3-requests"
        echo "  2. Virtual env:     python3 -m venv ~/venv-lab && source ~/venv-lab/bin/activate && pip install -r requirements.txt"
        echo ""
        exit 1
    fi
    python3 scripts/analyze-link-utilization.py
    ;;
    
  check-metrics)
    echo "🔍 Checking metrics availability..."
    ./scripts/check-metrics.sh
    ;;
    
  generate-traffic)
    echo "🚦 Generating test traffic..."
    ./scripts/generate-traffic.sh
    ;;
    
  grafana)
    echo "📊 Opening Grafana..."
    open http://localhost:3000 2>/dev/null || echo "Grafana: http://localhost:3000"
    ;;
    
  prometheus)
    echo "📈 Opening Prometheus..."
    open http://localhost:9090 2>/dev/null || echo "Prometheus: http://localhost:9090"
    ;;
    
  help|*)
    cat << 'HELP'
Lab Management Script

Usage: orb -m clab ./lab <command> [options]

Network Lab Commands:
  start, deploy          Deploy the network lab
  stop, destroy          Destroy the network lab
  restart                Restart the network lab
  configure              Configure network with Ansible
  verify                 Verify network configuration
  verify-detailed        Detailed verification with status

Monitoring Commands:
  mon-start              Deploy monitoring stack
  mon-stop               Destroy monitoring stack
  status                 Show lab and monitoring status
  check-metrics          Verify metrics are being collected
  analyze-links          Analyze link utilization and ECMP balance
  generate-traffic       Generate test traffic between clients

Container Commands:
  logs <node>            Show logs (default: spine1)
  shell <node>           Open bash shell (default: spine1)
  sr_cli <node>          Open SR Linux CLI (default: spine1)

Access Commands:
  grafana                Open Grafana
  prometheus             Open Prometheus
  help                   Show this help

Examples:
  orb -m clab ./lab start              # Deploy network lab
  orb -m clab ./lab mon-start          # Deploy monitoring
  orb -m clab ./lab configure          # Configure with Ansible
  orb -m clab ./lab verify             # Verify configuration
  orb -m clab ./lab check-metrics      # Verify metrics collection
  orb -m clab ./lab generate-traffic   # Generate test traffic
  orb -m clab ./lab analyze-links      # Analyze link utilization
  orb -m clab ./lab sr_cli spine1      # Access spine1 CLI
  orb -m clab ./lab logs leaf1         # View leaf1 logs
  orb -m clab ./lab status             # Check status

Monitoring:
  From host machine (outside orb VM):
    Grafana:    http://localhost:3000 (admin/admin)
    Prometheus: http://localhost:9090
    gNMIc:      http://localhost:9273/metrics
  
  From inside orb VM (for scripts):
    Grafana:    http://172.20.20.2:3000
    Prometheus: http://172.20.20.3:9090
    gNMIc:      http://172.20.20.5:9273/metrics

Network Nodes:
  spine1, spine2
  leaf1, leaf2, leaf3, leaf4
  client1, client2, client3, client4

Monitoring Nodes:
  grafana, prometheus, gnmic
HELP
    ;;
esac
