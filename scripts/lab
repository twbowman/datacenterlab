#!/bin/bash
# Lab management wrapper — runs commands on a remote Linux server via SSH.
#
# Usage:
#   ./lab deploy [srlinux|sonic]     Deploy a topology
#   ./lab destroy [srlinux|sonic]    Destroy a topology
#   ./lab configure [playbook]       Run Ansible playbook
#   ./lab validate                   Run validation playbook
#   ./lab status                     Show running containers
#   ./lab sync                       Sync repo to remote (no deploy)
#   ./lab ssh                        Open SSH session to remote
#   ./lab exec <cmd>                 Run arbitrary command on remote
#   ./lab tunnel                     Open SSH tunnels (Grafana, Prometheus)
#   ./lab setup                      Run first-time server setup

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# Load config
ENV_FILE="$PROJECT_ROOT/.env"
if [ ! -f "$ENV_FILE" ]; then
    echo -e "${RED}Missing .env file. Copy the example and configure it:${NC}"
    echo "  cp .env.example .env"
    exit 1
fi
# shellcheck source=/dev/null
source "$ENV_FILE"

# Validate required config
: "${LAB_HOST:?Set LAB_HOST in .env}"
LAB_USER="${LAB_USER:-root}"
LAB_SSH_KEY="${LAB_SSH_KEY:-$HOME/.ssh/id_ed25519}"
LAB_PORT="${LAB_PORT:-22}"
LAB_REMOTE_DIR="${LAB_REMOTE_DIR:-/opt/containerlab}"
LAB_VENDOR="${LAB_VENDOR:-srlinux}"

SSH_OPTS="-o StrictHostKeyChecking=accept-new -o ConnectTimeout=10 -i $LAB_SSH_KEY -p $LAB_PORT"
SSH_CMD="ssh $SSH_OPTS $LAB_USER@$LAB_HOST"

# ─────────────────────────────────────────────────────────────
# Helper functions
# ─────────────────────────────────────────────────────────────

remote() {
    # Run a command on the remote server
    $SSH_CMD "cd $LAB_REMOTE_DIR && $*"
}

sync_repo() {
    echo -e "${CYAN}Syncing repo to ${LAB_USER}@${LAB_HOST}:${LAB_REMOTE_DIR}...${NC}"
    rsync -az --delete \
        --exclude '.venv' \
        --exclude '.git' \
        --exclude '__pycache__' \
        --exclude '*.pyc' \
        --exclude '.mypy_cache' \
        --exclude '.ruff_cache' \
        --exclude '.hypothesis' \
        --exclude '.pytest_cache' \
        --exclude 'node_modules' \
        -e "ssh $SSH_OPTS" \
        "$PROJECT_ROOT/" \
        "$LAB_USER@$LAB_HOST:$LAB_REMOTE_DIR/"
    echo -e "${GREEN}Sync complete.${NC}"
}

# ─────────────────────────────────────────────────────────────
# Commands
# ─────────────────────────────────────────────────────────────

cmd_deploy() {
    local vendor="${1:-$LAB_VENDOR}"
    local topo="topology-${vendor}.yml"

    sync_repo
    echo -e "${GREEN}Deploying ${vendor} topology...${NC}"
    remote "sudo containerlab deploy -t ${topo} --reconfigure"
    echo ""
    echo -e "${GREEN}Deployment complete.${NC}"
    echo -e "${CYAN}Run './lab status' to see containers.${NC}"
}

cmd_destroy() {
    local vendor="${1:-$LAB_VENDOR}"
    local topo="topology-${vendor}.yml"

    echo -e "${YELLOW}Destroying ${vendor} topology...${NC}"
    remote "sudo containerlab destroy -t ${topo} --cleanup" || true
    echo -e "${GREEN}Destroyed.${NC}"
}

cmd_configure() {
    local playbook="${1:-ansible/methods/srlinux_gnmi/site.yml}"
    local inventory="${2:-ansible/inventory.yml}"

    sync_repo
    echo -e "${GREEN}Running: ansible-playbook -i ${inventory} ${playbook}${NC}"
    remote "ansible-playbook -i ${inventory} ${playbook}"
}

cmd_validate() {
    sync_repo
    local inventory="ansible/inventory.yml"
    if remote "test -f ansible/inventory-dynamic.yml" 2>/dev/null; then
        inventory="ansible/inventory-dynamic.yml"
    fi

    echo -e "${GREEN}Running validation...${NC}"
    remote "ANSIBLE_CALLBACK_PLUGINS=ansible/callback_plugins \
            ANSIBLE_CALLBACKS_ENABLED=validation_report \
            ansible-playbook -i ${inventory} ansible/playbooks/validate.yml"
}

cmd_status() {
    echo -e "${CYAN}Lab status on ${LAB_HOST}:${NC}"
    remote "sudo containerlab inspect --all" 2>/dev/null || echo "No topologies running."
    echo ""
    remote "docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'" 2>/dev/null || true
}

cmd_sync() {
    sync_repo
}

cmd_ssh() {
    echo -e "${CYAN}Connecting to ${LAB_HOST}...${NC}"
    $SSH_CMD -t "cd $LAB_REMOTE_DIR && exec \$SHELL -l"
}

cmd_exec() {
    remote "$@"
}

cmd_tunnel() {
    echo -e "${CYAN}Opening SSH tunnels to ${LAB_HOST}...${NC}"
    echo "  Grafana:    http://localhost:3000"
    echo "  Prometheus: http://localhost:9090"
    echo "  gNMIc:      http://localhost:9273"
    echo ""
    echo -e "${YELLOW}Press Ctrl+C to close tunnels.${NC}"
    $SSH_CMD -N \
        -L 3000:localhost:3000 \
        -L 9090:localhost:9090 \
        -L 9273:localhost:9273
}

cmd_setup() {
    echo -e "${GREEN}Running first-time setup on ${LAB_HOST}...${NC}"
    scp $SSH_OPTS "$SCRIPT_DIR/remote-setup.sh" "$LAB_USER@$LAB_HOST:/tmp/remote-setup.sh"
    $SSH_CMD "chmod +x /tmp/remote-setup.sh && /tmp/remote-setup.sh"
    echo ""
    echo -e "${GREEN}Setup complete. You can now run: ./lab deploy${NC}"
}

# ─────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────

usage() {
    echo "Usage: ./lab <command> [args]"
    echo ""
    echo "Commands:"
    echo "  deploy [srlinux|sonic]     Deploy a topology (default: $LAB_VENDOR)"
    echo "  destroy [srlinux|sonic]    Destroy a topology"
    echo "  configure [playbook]       Run Ansible playbook"
    echo "  validate                   Run validation checks"
    echo "  status                     Show running containers"
    echo "  sync                       Sync repo to remote server"
    echo "  ssh                        Open SSH session"
    echo "  exec <cmd>                 Run command on remote"
    echo "  tunnel                     Open SSH tunnels (Grafana, Prometheus)"
    echo "  setup                      First-time server setup"
    echo ""
    echo "Config: $ENV_FILE"
    echo "Remote: ${LAB_USER}@${LAB_HOST}:${LAB_REMOTE_DIR}"
}

COMMAND="${1:-}"
shift 2>/dev/null || true

case "$COMMAND" in
    deploy)     cmd_deploy "$@" ;;
    destroy)    cmd_destroy "$@" ;;
    configure)  cmd_configure "$@" ;;
    validate)   cmd_validate ;;
    status)     cmd_status ;;
    sync)       cmd_sync ;;
    ssh)        cmd_ssh ;;
    exec)       cmd_exec "$@" ;;
    tunnel)     cmd_tunnel ;;
    setup)      cmd_setup ;;
    help|--help|-h|"")
        usage ;;
    *)
        echo -e "${RED}Unknown command: ${COMMAND}${NC}"
        usage
        exit 1 ;;
esac
